# คัดลอกไฟล์นี้เป็น .env ก่อนรัน: cp .env.example .env
# docker compose จะอ่านค่าจาก .env โดยอัตโนมัติ

# ----- PostgreSQL credentials (ใช้โดย service db และประกอบเป็น DATABASE_URL) -----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=welcomeweb

# ----- Connection string สำหรับแอป -----
# ใน Docker: host คือชื่อ service "db" (compose ตั้ง DATABASE_URL ให้เองอยู่แล้ว)
# สำหรับรัน local dev นอก Docker: ใช้ localhost ตามด้านล่าง
DATABASE_URL=postgres://postgres:postgres@localhost:5432/welcomeweb

# ----- Secret สำหรับเซ็นลายเซ็น session cookie -----
# production: เปลี่ยนเป็นค่าสุ่มยาว ๆ เช่น `openssl rand -base64 32`
SESSION_SECRET=change-me-to-a-long-random-string
