# บังคับ line ending ให้คงที่ ไม่ว่าจะ clone บน OS ไหน หรือ core.autocrlf เป็นอะไร
# ป้องกันปัญหา CRLF ทำให้ shell script รันใน Linux container ไม่ได้

# ค่า default: ให้ Git จัดการ text เอง แต่ normalize เป็น LF ใน repository
* text=auto eol=lf

# ไฟล์ที่ "ต้อง" เป็น LF เสมอ (sensitive กับ line ending เมื่อรันบน Linux)
*.sh         text eol=lf
Dockerfile   text eol=lf
*.Dockerfile text eol=lf
docker-entrypoint.sh text eol=lf
.env         text eol=lf
.env.*       text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.json       text eol=lf
*.ts         text eol=lf
*.tsx        text eol=lf
*.js         text eol=lf
*.mjs        text eol=lf
*.cjs        text eol=lf
*.css        text eol=lf
*.sql        text eol=lf
*.md         text eol=lf

# ไฟล์ binary — ห้าม Git แตะ line ending
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
